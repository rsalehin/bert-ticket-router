# Copy this file to `.env` and adjust values for your local environment.
# All variables are optional; omitted ones use defaults from src/config.py.
# `.env` is gitignored; `.env.example` is committed.

# ----- Paths -----
APP_MODEL_CHECKPOINT_PATH=artifacts/model
APP_ROUTING_CONFIG_PATH=configs/routing.yaml
APP_DB_URL=sqlite:///artifacts/tickets.db

# ----- Model and inference -----
APP_BASE_MODEL_NAME=bert-base-uncased
APP_MAX_LEN=64
APP_TOP_K=3
APP_DEVICE=auto

# ----- Training (used by train.py only) -----
APP_BATCH_SIZE=64
APP_LEARNING_RATE=2e-5
APP_NUM_EPOCHS=4
APP_WEIGHT_DECAY=0.01
APP_WARMUP_RATIO=0.1
APP_SEED=42

# ----- Server -----
APP_LOG_LEVEL=INFO
APP_MODEL_VERSION=bert-base-uncased@v0.1.0-dev
